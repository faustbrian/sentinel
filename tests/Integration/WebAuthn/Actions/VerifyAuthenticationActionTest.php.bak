describe('Sad Path - Invalid Response Type', function (): void {
    test('throws exception when credential response is not AuthenticatorAssertionResponse', function (): void {
        // Arrange - Create PublicKeyCredential with wrong response type
        $publicKeyCredential = Mockery::mock(PublicKeyCredential::class);
        $publicKeyCredential->rawId = random_bytes(16);
        $publicKeyCredential->response = new stdClass(); // Wrong type

        $credentialJson = $this->serializer->toJson($publicKeyCredential);
        $optionsJson = $this->serializer->toJson(Mockery::mock(PublicKeyCredentialRequestOptions::class));

        // Act & Assert
        expect(fn () => $this->action->execute($credentialJson, $optionsJson, 'localhost'))
            ->toThrow(InvalidWebAuthnAssertionException::class, 'Invalid credential response type. Expected assertion response.');
    });
});

describe('Sad Path - Validation Failures', function (): void {
    test('throws exception when ceremony validation fails', function (): void {
        // Arrange
        $credentialId = random_bytes(16);
        $storedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: Uuid::v4(),
            credentialPublicKey: random_bytes(77),
            userHandle: (string) $this->user->id,
            counter: 0,
        );

        MultiFactorCredential::query()->create([
            'id' => Str::uuid()->toString(),
            'user_id' => $this->user->id,
            'type' => 'webauthn',
            'name' => 'Security Key',
            'secret' => $this->serializer->toJson($storedSource),
            'created_at' => now(),
        ]);

        $publicKeyCredential = Mockery::mock(PublicKeyCredential::class);
        $publicKeyCredential->rawId = $credentialId;
        $publicKeyCredential->response = Mockery::mock(AuthenticatorAssertionResponse::class);

        $credentialJson = $this->serializer->toJson($publicKeyCredential);
        $optionsJson = $this->serializer->toJson(Mockery::mock(PublicKeyCredentialRequestOptions::class));

        // Mock validator to throw exception
        $this->mock(AuthenticatorAssertionResponseValidator::class, function ($mock): void {
            $mock->shouldReceive('check')
                ->andThrow(new Exception('Signature validation failed'));
        });

        // Act & Assert
        expect(fn () => $this->action->execute($credentialJson, $optionsJson, 'localhost'))
            ->toThrow(InvalidWebAuthnAssertionException::class, 'WebAuthn assertion verification failed: Signature validation failed');
    });

    test('wraps validation exceptions with descriptive message', function (): void {
        // Arrange
        $credentialId = random_bytes(16);
        $storedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: Uuid::v4(),
            credentialPublicKey: random_bytes(77),
            userHandle: (string) $this->user->id,
            counter: 0,
        );

        MultiFactorCredential::query()->create([
            'id' => Str::uuid()->toString(),
            'user_id' => $this->user->id,
            'type' => 'webauthn',
            'name' => 'Security Key',
            'secret' => $this->serializer->toJson($storedSource),
            'created_at' => now(),
        ]);

        $publicKeyCredential = Mockery::mock(PublicKeyCredential::class);
        $publicKeyCredential->rawId = $credentialId;
        $publicKeyCredential->response = Mockery::mock(AuthenticatorAssertionResponse::class);

        $credentialJson = $this->serializer->toJson($publicKeyCredential);
        $optionsJson = $this->serializer->toJson(Mockery::mock(PublicKeyCredentialRequestOptions::class));

        $originalException = new RuntimeException('Counter validation failed');

        $this->mock(AuthenticatorAssertionResponseValidator::class, function ($mock) use ($originalException): void {
            $mock->shouldReceive('check')->andThrow($originalException);
        });

        // Act & Assert
        try {
            $this->action->execute($credentialJson, $optionsJson, 'localhost');
            $this->fail('Expected InvalidWebAuthnAssertionException to be thrown');
        } catch (InvalidWebAuthnAssertionException $e) {
            expect($e->getMessage())->toContain('WebAuthn assertion verification failed')
                ->and($e->getMessage())->toContain('Counter validation failed')
                ->and($e->getPrevious())->toBe($originalException);
        }
    });
});

describe('Edge Cases - Credential Lookup with Encoding', function (): void {
    test('correctly finds credential using mb_convert_encoding', function (): void {
        // Arrange - Create multiple credentials
        $targetCredentialId = random_bytes(32);
        $otherCredentialId1 = random_bytes(32);
        $otherCredentialId2 = random_bytes(32);

        foreach ([$otherCredentialId1, $targetCredentialId, $otherCredentialId2] as $index => $credId) {
            $source = PublicKeyCredentialSource::create(
                publicKeyCredentialId: $credId,
                type: 'public-key',
                transports: [],
                attestationType: 'none',
                trustPath: new EmptyTrustPath(),
                aaguid: Uuid::v4(),
                credentialPublicKey: random_bytes(77),
                userHandle: (string) $this->user->id,
                counter: $index,
            );

            MultiFactorCredential::query()->create([
                'id' => Str::uuid()->toString(),
                'user_id' => $this->user->id,
                'type' => $index === 1 ? 'webauthn' : 'passkey',
                'name' => "Key {$index}",
                'secret' => $this->serializer->toJson($source),
                'created_at' => now(),
            ]);
        }

        $updatedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $targetCredentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: Uuid::v4(),
            credentialPublicKey: random_bytes(77),
            userHandle: (string) $this->user->id,
            counter: 2,
        );

        $publicKeyCredential = Mockery::mock(PublicKeyCredential::class);
        $publicKeyCredential->rawId = $targetCredentialId;
        $publicKeyCredential->response = Mockery::mock(AuthenticatorAssertionResponse::class);

        $credentialJson = $this->serializer->toJson($publicKeyCredential);
        $optionsJson = $this->serializer->toJson(Mockery::mock(PublicKeyCredentialRequestOptions::class));

        $this->mock(AuthenticatorAssertionResponseValidator::class, function ($mock) use ($updatedSource): void {
            $mock->shouldReceive('check')->andReturn($updatedSource);
        });

        // Act
        $result = $this->action->execute($credentialJson, $optionsJson, 'localhost');

        // Assert
        expect($result->name)->toBe('Key 1')
            ->and($result->type)->toBe('webauthn');
    });

    test('handles binary credential IDs with special characters', function (): void {
        // Arrange - Create credential with binary ID containing special bytes
        $credentialId = "\x00\xFF\x80\x7F".random_bytes(12);

        $storedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: Uuid::v4(),
            credentialPublicKey: random_bytes(77),
            userHandle: (string) $this->user->id,
            counter: 0,
        );

        MultiFactorCredential::query()->create([
            'id' => Str::uuid()->toString(),
            'user_id' => $this->user->id,
            'type' => 'webauthn',
            'name' => 'Special Key',
            'secret' => $this->serializer->toJson($storedSource),
            'created_at' => now(),
        ]);

        $updatedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: $storedSource->aaguid,
            credentialPublicKey: $storedSource->credentialPublicKey,
            userHandle: (string) $this->user->id,
            counter: 1,
        );

        $publicKeyCredential = Mockery::mock(PublicKeyCredential::class);
        $publicKeyCredential->rawId = $credentialId;
        $publicKeyCredential->response = Mockery::mock(AuthenticatorAssertionResponse::class);

        $credentialJson = $this->serializer->toJson($publicKeyCredential);
        $optionsJson = $this->serializer->toJson(Mockery::mock(PublicKeyCredentialRequestOptions::class));

        $this->mock(AuthenticatorAssertionResponseValidator::class, function ($mock) use ($updatedSource): void {
            $mock->shouldReceive('check')->andReturn($updatedSource);
        });

        // Act
        $result = $this->action->execute($credentialJson, $optionsJson, 'localhost');

        // Assert
        expect($result->name)->toBe('Special Key');
    });
});

describe('Edge Cases - Signature Counter Updates', function (): void {
    test('updates credential with new counter value from validator', function (): void {
        // Arrange
        $credentialId = random_bytes(16);
        $initialCounter = 100;
        $newCounter = 150;

        $storedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: Uuid::v4(),
            credentialPublicKey: random_bytes(77),
            userHandle: (string) $this->user->id,
            counter: $initialCounter,
        );

        $credential = MultiFactorCredential::query()->create([
            'id' => Str::uuid()->toString(),
            'user_id' => $this->user->id,
            'type' => 'webauthn',
            'name' => 'Security Key',
            'secret' => $this->serializer->toJson($storedSource),
            'created_at' => now(),
        ]);

        $updatedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: $storedSource->aaguid,
            credentialPublicKey: $storedSource->credentialPublicKey,
            userHandle: (string) $this->user->id,
            counter: $newCounter,
        );

        $publicKeyCredential = Mockery::mock(PublicKeyCredential::class);
        $publicKeyCredential->rawId = $credentialId;
        $publicKeyCredential->response = Mockery::mock(AuthenticatorAssertionResponse::class);

        $credentialJson = $this->serializer->toJson($publicKeyCredential);
        $optionsJson = $this->serializer->toJson(Mockery::mock(PublicKeyCredentialRequestOptions::class));

        $this->mock(AuthenticatorAssertionResponseValidator::class, function ($mock) use ($updatedSource): void {
            $mock->shouldReceive('check')->andReturn($updatedSource);
        });

        // Act
        $this->action->execute($credentialJson, $optionsJson, 'localhost');

        // Assert
        $credential->refresh();
        $deserializedSource = $this->serializer->fromJson(
            $credential->secret,
            PublicKeyCredentialSource::class,
        );

        expect($deserializedSource->counter)->toBe($newCounter)
            ->and($deserializedSource->counter)->not->toBe($initialCounter);
    });

    test('persists all credential source properties after update', function (): void {
        // Arrange
        $credentialId = random_bytes(16);
        $aaguid = Uuid::v4();
        $publicKey = random_bytes(77);
        $transports = ['usb', 'nfc'];

        $storedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: $transports,
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: $aaguid,
            credentialPublicKey: $publicKey,
            userHandle: (string) $this->user->id,
            counter: 10,
        );

        $credential = MultiFactorCredential::query()->create([
            'id' => Str::uuid()->toString(),
            'user_id' => $this->user->id,
            'type' => 'webauthn',
            'name' => 'Security Key',
            'secret' => $this->serializer->toJson($storedSource),
            'created_at' => now(),
        ]);

        $updatedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: $transports,
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: $aaguid,
            credentialPublicKey: $publicKey,
            userHandle: (string) $this->user->id,
            counter: 11,
        );

        $publicKeyCredential = Mockery::mock(PublicKeyCredential::class);
        $publicKeyCredential->rawId = $credentialId;
        $publicKeyCredential->response = Mockery::mock(AuthenticatorAssertionResponse::class);

        $credentialJson = $this->serializer->toJson($publicKeyCredential);
        $optionsJson = $this->serializer->toJson(Mockery::mock(PublicKeyCredentialRequestOptions::class));

        $this->mock(AuthenticatorAssertionResponseValidator::class, function ($mock) use ($updatedSource): void {
            $mock->shouldReceive('check')->andReturn($updatedSource);
        });

        // Act
        $this->action->execute($credentialJson, $optionsJson, 'localhost');

        // Assert - Verify all properties are preserved
        $credential->refresh();
        $deserializedSource = $this->serializer->fromJson(
            $credential->secret,
            PublicKeyCredentialSource::class,
        );

        expect($deserializedSource->publicKeyCredentialId)->toBe($credentialId)
            ->and($deserializedSource->type)->toBe('public-key')
            ->and($deserializedSource->transports)->toBe($transports)
            ->and($deserializedSource->aaguid->toRfc4122())->toBe($aaguid->toRfc4122())
            ->and($deserializedSource->credentialPublicKey)->toBe($publicKey)
            ->and($deserializedSource->counter)->toBe(11);
    });
});

describe('Integration - User Relationship', function (): void {
    test('returned credential maintains user relationship', function (): void {
        // Arrange
        $credentialId = random_bytes(16);

        $storedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: Uuid::v4(),
            credentialPublicKey: random_bytes(77),
            userHandle: (string) $this->user->id,
            counter: 0,
        );

        MultiFactorCredential::query()->create([
            'id' => Str::uuid()->toString(),
            'user_id' => $this->user->id,
            'type' => 'webauthn',
            'name' => 'Security Key',
            'secret' => $this->serializer->toJson($storedSource),
            'created_at' => now(),
        ]);

        $updatedSource = PublicKeyCredentialSource::create(
            publicKeyCredentialId: $credentialId,
            type: 'public-key',
            transports: [],
            attestationType: 'none',
            trustPath: new EmptyTrustPath(),
            aaguid: $storedSource->aaguid,
            credentialPublicKey: $storedSource->credentialPublicKey,
            userHandle: (string) $this->user->id,
            counter: 1,
        );

        $publicKeyCredential = Mockery::mock(PublicKeyCredential::class);
        $publicKeyCredential->rawId = $credentialId;
        $publicKeyCredential->response = Mockery::mock(AuthenticatorAssertionResponse::class);

        $credentialJson = $this->serializer->toJson($publicKeyCredential);
        $optionsJson = $this->serializer->toJson(Mockery::mock(PublicKeyCredentialRequestOptions::class));

        $this->mock(AuthenticatorAssertionResponseValidator::class, function ($mock) use ($updatedSource): void {
            $mock->shouldReceive('check')->andReturn($updatedSource);
        });

        // Act
        $result = $this->action->execute($credentialJson, $optionsJson, 'localhost');

        // Assert
        expect($result->user)->not->toBeNull()
            ->and($result->user->id)->toBe($this->user->id)
            ->and($result->user->email)->toBe($this->user->email);
    });
});
